# Admin Frontend environment
# Public API base URL for all browser-side requests.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Optional metadata used by the UI/build-time diagnostics.
NEXT_PUBLIC_APP_NAME=ERP Admin Frontend
NEXT_PUBLIC_APP_ROLE=admin

# Demo credentials shown on the admin login screen.
NEXT_PUBLIC_ADMIN_DEMO_USER=admin
NEXT_PUBLIC_ADMIN_DEMO_PASSWORD=admin123
